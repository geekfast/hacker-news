# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual API keys

# =============================================================================
# AI API KEYS (for AI-powered summaries)
# =============================================================================

# Google Gemini API Key (Primary AI service)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Fallback AI service)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# IMAGE SEARCH API (for story thumbnails)
# =============================================================================

# Unsplash Access Key (for image search)
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# =============================================================================
# REDDIT API (for Reddit story integration)
# =============================================================================

# Reddit Application Credentials
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Reddit User Agent (required by Reddit API)
REDDIT_USER_AGENT=web:hacker-news-clone:1.0 (by /u/your_username)

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Reddit API timeout (milliseconds)
REDDIT_TIMEOUT_MS=30000

# Enable Reddit fallback when API fails
REDDIT_FALLBACK_ENABLED=true

# Development/Production settings (automatically set by Next.js and Vercel)
# NODE_ENV=development
# VERCEL=1
# VERCEL_URL=your-app.vercel.app
# VERCEL_REGION=iad1
